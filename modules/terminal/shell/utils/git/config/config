[push]
    autoSetupRemote = true
[alias]
    whoami = !git config user.name && git config user.email
    tree = "!f() { mapfile -t repos < <(find . -mindepth 1 -name \".git\" -type d | sed 's|/.git$||' | sed 's|^\\./||' | sort); if [ -d \".git\" ]; then branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null); repo_name=$(basename \"$(pwd)\"); echo \". $repo_name [$branch]\"; else echo \".\"; fi; declare -A all_paths; for repo in \"${repos[@]}\"; do all_paths[\"$repo\"]=1; path=\"$repo\"; while [[ \"$path\" == */* ]]; do path=\"${path%/*}\"; [[ -n \"$path\" && \"$path\" != \".\" ]] && all_paths[\"$path\"]=1; done; done; mapfile -t sorted_paths < <(printf \"%s\\n\" \"${!all_paths[@]}\" | sort); for item in \"${sorted_paths[@]}\"; do [[ -z \"$item\" || \"$item\" == \".\" ]] && continue; if [ -d \"./$item/.git\" ]; then branch=$(cd \"./$item\" && git rev-parse --abbrev-ref HEAD 2>/dev/null); name=\"$(basename \"$item\") [$branch]\"; else name=\"$(basename \"$item\")\"; fi; depth=$(grep -o \"/\" <<< \"$item\" | wc -c); parent=\"${item%/*}\"; [[ \"$parent\" == \"$item\" ]] && parent=\"\"; if [ -z \"$parent\" ]; then mapfile -t siblings < <(printf \"%s\\n\" \"${sorted_paths[@]}\" | grep \"^[^/]*$\" | sort); else mapfile -t siblings < <(printf \"%s\\n\" \"${sorted_paths[@]}\" | grep \"^${parent}/[^/]*$\" | sort); fi; last_sibling=\"${siblings[-1]}\"; if [ \"$item\" = \"$last_sibling\" ]; then connector=\"└── \"; else connector=\"├── \"; fi; indent=\"\"; if [ $depth -gt 0 ]; then IFS='/' read -ra parts <<< \"$item\"; current=\"\"; for ((i=0; i<${#parts[@]}-1; i++)); do [ $i -gt 0 ] && current+=\"/\"; current+=\"${parts[$i]}\"; ancestor_parent=\"${current%/*}\"; [[ \"$ancestor_parent\" == \"$current\" ]] && ancestor_parent=\"\"; if [ -z \"$ancestor_parent\" ]; then mapfile -t ancestor_siblings < <(printf \"%s\\n\" \"${sorted_paths[@]}\" | grep \"^[^/]*$\" | sort); else mapfile -t ancestor_siblings < <(printf \"%s\\n\" \"${sorted_paths[@]}\" | grep \"^${ancestor_parent}/[^/]*$\" | sort); fi; last_ancestor=\"${ancestor_siblings[-1]}\"; if [ \"$current\" = \"$last_ancestor\" ]; then indent+=\"    \"; else indent+=\"│   \"; fi; done; fi; echo \"${indent}${connector}${name}\"; done; }; f"
